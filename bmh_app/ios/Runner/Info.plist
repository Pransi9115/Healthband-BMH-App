<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ── Bluetooth ── -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>BMH uses Bluetooth to connect to your Health Band and BioScale to read your health data in real time.</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>BMH uses Bluetooth to connect to your health devices.</string>

    <!-- ── Location (required for BLE scan on iOS) ── -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>BMH needs location access to scan for nearby Bluetooth devices.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>BMH uses location to scan for Bluetooth health devices in the background.</string>

    <!-- ── Health Kit ── -->
    <key>NSHealthShareUsageDescription</key>
    <string>BMH reads health data to provide you with comprehensive health insights.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>BMH writes workout and health data to Apple Health.</string>

    <!-- ── Motion & Fitness ── -->
    <key>NSMotionUsageDescription</key>
    <string>BMH uses motion data to track your physical activity and step count.</string>

    <!-- ── Camera (for QR code pairing) ── -->
    <key>NSCameraUsageDescription</key>
    <string>BMH uses the camera to scan QR codes for device pairing.</string>

    <!-- ── Encryption ── -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

    <!-- ── Background Modes ── -->
    <key>UIBackgroundModes</key>
    <array>
        <string>bluetooth-central</string>
        <string>bluetooth-peripheral</string>
        <string>fetch</string>
        <string>remote-notification</string>
    </array>

    <!-- ── App Info ── -->
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>BMH</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>bmh_app</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>

    <!-- ── Orientations ── -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

</dict>
</plist>
